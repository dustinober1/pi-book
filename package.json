{
  "name": "novel-forge-for-pi",
  "version": "1.0.0",
  "description": "A compact, series-capable Pi workflow for high-quality thriller and romantasy novels.",
  "private": true,
  "license": "UNLICENSED",
  "type": "module",
  "repository": { "type": "git", "url": "https://github.com/dustinober1/pi-book.git" },
  "keywords": ["pi-package", "novel-writing", "thriller", "romantasy", "series-writing", "continuity"],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test tests/*.test.ts tests/e2e/*.test.ts",
    "test:e2e": "node --import tsx --test tests/e2e/*.test.ts",
    "audit:ngrams": "node scripts/ngram-audit.mjs",
    "audit:rhetoric": "node scripts/rhetorical-pattern-audit.mjs",
    "audit:continuity": "node scripts/continuity-scan.mjs",
    "audit:integrity": "node scripts/integrity-audit.mjs",
    "audit:structure": "node scripts/structure-audit.mjs",
    "audit:spelling": "node scripts/spelling-consistency-audit.mjs",
    "audit:temporal": "node scripts/temporal-reference-audit.mjs",
    "audit:mechanics": "node scripts/copy-mechanics-audit.mjs",
    "eval": "node --import tsx scripts/evaluate-fixtures.ts"
  },
  "pi": { "skills": ["."], "extensions": ["extensions/novel-forge.ts"] },
  "files": ["SKILL.md", "README.md", "agents/", "extensions/", "src/", "profiles/", "references/", "scripts/"],
  "dependencies": { "@sinclair/typebox": "^0.34.52", "typebox": "^1.3.3", "yaml": "^2.9.0" },
  "devDependencies": { "@earendil-works/pi-coding-agent": "0.80.3", "@types/node": "^24.0.0", "tsx": "^4.20.6", "typescript": "^5.9.3" },
  "peerDependencies": { "@earendil-works/pi-coding-agent": "^0.80.3" }
}
