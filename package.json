{
  "name": "genesis-for-pi",
  "version": "0.4.0",
  "description": "Genesis for Pi: an extension-first Book Genesis workflow with PRD-first intake, writer-gated automation, single-book and whole-series commands, blocker clearing, voice protection, audits, Genesis Score, and editorial packaging.",
  "private": true,
  "repository": {
    "type": "git",
    "url": "https://github.com/dustinober1/pi-book.git"
  },
  "homepage": "https://github.com/dustinober1/pi-book",
  "bugs": {
    "url": "https://github.com/dustinober1/pi-book/issues"
  },
  "type": "module",
  "keywords": [
    "pi-package",
    "pi-extension",
    "pi-skill",
    "agent-skill",
    "book-genesis",
    "genesis",
    "book-writing",
    "writing"
  ],
  "license": "UNLICENSED",
  "scripts": {
    "test": "node scripts/validate-genesis-package.mjs && node scripts/test-genesis-sample-projects.mjs",
    "audit:ngrams": "node scripts/ngram-audit.mjs",
    "audit:rhetoric": "node scripts/rhetorical-pattern-audit.mjs",
    "audit:continuity": "node scripts/continuity-scan.mjs",
    "audit:structure": "node scripts/structure-audit.mjs",
    "audit:spelling": "node scripts/spelling-consistency-audit.mjs"
  },
  "pi": {
    "skills": [
      "."
    ],
    "prompts": [
      "prompts"
    ],
    "extensions": [
      "extensions"
    ]
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*"
  },
  "files": [
    "SKILL.md",
    "agents/",
    "references/",
    "prompts/",
    "extensions/",
    "docs/",
    "examples/",
    "scripts/ngram-audit.mjs",
    "scripts/rhetorical-pattern-audit.mjs",
    "scripts/continuity-scan.mjs",
    "scripts/structure-audit.mjs",
    "scripts/spelling-consistency-audit.mjs",
    "README.md"
  ],
  "devDependencies": {
    "@types/node": "^26.1.0"
  },
  "dependencies": {
    "typebox": "^1.3.3"
  }
}
