{
  "name": "novel-forge-for-pi",
  "version": "1.4.1",
  "description": "A guided, series-capable Pi workflow for high-quality thriller and romantasy novels.",
  "private": true,
  "license": "UNLICENSED",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/dustinober1/pi-book.git"
  },
  "keywords": [
    "pi-package",
    "novel-writing",
    "thriller",
    "romantasy",
    "series-writing",
    "continuity"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test tests/*.test.ts tests/e2e/*.test.ts",
    "test:e2e": "node --import tsx --test tests/e2e/*.test.ts",
    "audit:voice": "node --import tsx scripts/voice-audit.ts",
    "audit:ngrams": "node scripts/ngram-audit.mjs",
    "audit:rhetoric": "node scripts/rhetorical-pattern-audit.mjs",
    "audit:continuity": "node scripts/continuity-scan.mjs",
    "audit:integrity": "node scripts/integrity-audit.mjs",
    "audit:structure": "node scripts/structure-audit.mjs",
    "audit:spelling": "node scripts/spelling-consistency-audit.mjs",
    "audit:temporal": "node scripts/temporal-reference-audit.mjs",
    "audit:mechanics": "node scripts/copy-mechanics-audit.mjs",
    "eval": "node --import tsx scripts/evaluate-fixtures.ts",
    "benchmark:constrained-runtime": "node --import tsx scripts/benchmark-constrained-runtime.ts",
    "benchmark:prompts": "node --import tsx scripts/benchmark-prompts.ts",
    "eval:journeys": "node --import tsx --test tests/author-journey.test.ts tests/e2e/author-velocity-baseline.test.ts",
    "verify:release": "node --import tsx scripts/verify-v1-4-release.ts",
    "test:release": "node --import tsx --test tests/v1-4-release-checklist.test.ts tests/e2e/v1-4-release-journey.test.ts tests/package-smoke.test.ts tests/e2e/packed-clean-start.test.ts"
  },
  "pi": {
    "skills": [
      "."
    ],
    "extensions": [
      "extensions/novel-forge.ts"
    ]
  },
  "files": [
    "SKILL.md",
    "README.md",
    "CHANGELOG.md",
    "RELEASE.md",
    "agents/",
    "extensions/",
    "src/",
    "profiles/",
    "references/",
    "scripts/",
    "wizard/"
  ],
  "dependencies": {
    "@sinclair/typebox": "^0.34.52",
    "busboy": "^1.6.0",
    "docx": "^9.7.1",
    "exceljs": "^4.4.0",
    "fast-xml-parser": "^5.10.0",
    "fflate": "^0.8.3",
    "mammoth": "^1.12.0",
    "marked": "^18.0.6",
    "open": "^11.0.0",
    "turndown": "^7.2.4",
    "turndown-plugin-gfm": "^1.0.2",
    "typebox": "^1.3.3",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@earendil-works/pi-coding-agent": "0.80.3",
    "@types/busboy": "^1.5.4",
    "@types/node": "^24.0.0",
    "@types/turndown": "^5.0.6",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "^0.80.3"
  }
}
